## Код для извлечения (с индексами DOM)

```javascript
function parseSearchPage() {
    const items = [];
    const cards = document.querySelectorAll('[data-marker="item"]');
    
    // Мета-данные страницы
    const meta = {
        query: new URLSearchParams(location.search).get('q'),
        city: location.pathname.split('/')[1],
        localPriority: parseInt(new URLSearchParams(location.search).get('localPriority')) || 0,
        totalCount: parseInt(document.querySelector('[data-marker="page-title/count"]')?.textContent?.replace(/\s/g, '') || '0')
    };
    
    cards.forEach((card, index) => {
        const item = {};
        
        // URL и ID
        const link = card.querySelector('a[data-marker="item-title"]');
        if (link) {
            item.url = link.href;
            item.id = link.href.match(/\/(\d+)(?:[\/\?]|$)/)?.[1];
            item.title = link.textContent.trim();
        }
        
        // Цена
        const priceEl = card.querySelector('[data-marker="item-price-value"]');
        const priceMeta = card.querySelector('meta[itemprop="price"]');
        const currencyMeta = card.querySelector('meta[itemprop="priceCurrency"]');
        item.price = {
            value: parseInt(priceMeta?.content) || parseInt(priceEl?.textContent?.replace(/[^\d]/g, '')),
            currency: currencyMeta?.content || 'RUB',
            formatted: priceEl?.textContent?.trim()
        };
        
        // Прайс-лист
        const priceListItems = card.querySelectorAll('.price-list-value-WxG6k');
        if (priceListItems.length) {
            item.price.priceList = Array.from(priceListItems).map(pli => ({
                name: pli.querySelector('.price-list-title-wj1z6')?.textContent?.trim(),
                price: pli.querySelector('.price-list-price-wFpMB')?.textContent?.trim()
            }));
        }
        
        // Локация
        const locationSpan = card.querySelector('.geo-pinIcon-GPsqD')?.parentElement;
        const extraLocation = card.querySelector('.geo-additionalInfo-KGO7g');
        const remoteSpan = Array.from(card.querySelectorAll('span')).find(s => s.textContent.includes('удалённо'));
        item.location = {
            district: locationSpan?.childNodes[0]?.textContent?.trim(),
            travels: !!extraLocation?.textContent?.includes('выезжает'),
            remoteOnly: !!remoteSpan,
            extra: extraLocation?.textContent?.trim()
        };
        
        // Описание
        const descEl = card.querySelector('p[style*="--module-max-lines-size:4"]');
        item.description = descEl?.textContent?.trim();
        
        // Изображения
        item.images = Array.from(card.querySelectorAll('[data-marker^="slider-image/image-"] img')).map(img => img.src);
        
        // Статусы
        item.promoted = !!card.querySelector('span')?.textContent?.includes('Продвинуто');
        item.category = Array.from(card.querySelectorAll('span')).find(s => s.textContent.includes('Предложение услуг'))?.textContent?.trim();
        
        // Продавец
        const sellerLink = card.querySelector('a[href*="/brands/"]') || card.querySelector('a[href*="/user/"]');
        if (sellerLink) {
            item.seller = {
                name: sellerLink.querySelector('p')?.textContent?.trim(),
                url: sellerLink.href,
                rating: parseFloat(card.querySelector('[data-marker="seller-rating/score"]')?.textContent?.replace(',', '.') || 
                         card.querySelector('meta[itemprop="ratingValue"]')?.content),
                reviews: parseInt(card.querySelector('[data-marker="seller-info/summary"]')?.textContent || '0'),
                entityType: mapEntityType(card.querySelector('.styles-wrapper-dIADx span')?.textContent),
                entityTypeLabel: card.querySelector('.styles-wrapper-dIADx span')?.textContent?.trim(),
                badges: Array.from(card.querySelectorAll('[data-marker^="badge-title-"] .SnippetBadge-title-NCaUc')).map(b => b.textContent.trim()),
                availability: card.querySelector('[data-marker="iva-item/2750"] .styles-module-content-M8Kp5')?.textContent?.trim(),
                hasPortfolio: !!card.querySelector('[data-marker="iva-item/2889"]'),
                dealProtection: !!card.querySelector('[data-marker="iva-item/2933"]')
            };
        }
        
        items.push(item);
    });
    
    return { meta, items };
}

function mapEntityType(label) {
    const map = {
        'Частный исполнитель': 'individual',
        'Частное лицо': 'individual',
        'Компания': 'company',
        'Команда': 'team',
        'ИП': 'entrepreneur',
        'Самозанятый': 'self_employed'
    };
    return map[label] || 'unknown';
}
```

